# i++ - increment digit mod 10
# Input: '0'-'9' (ASCII 48-57)
# Output: next digit mod 10

A<I         # read digit

# A is now 48-57
# We want to output (A - 48 + 1) mod 10 + 48
# Which is A + 1, but if A == 57, output 48

# Build a lookup table
[48]<49     # '0' -> '1'
[49]<50     # '1' -> '2'
[50]<51     # '2' -> '3'
[51]<52     # '3' -> '4'
[52]<53     # '4' -> '5'
[53]<54     # '5' -> '6'
[54]<55     # '6' -> '7'
[55]<56     # '7' -> '8'
[56]<57     # '8' -> '9'
[57]<48     # '9' -> '0'

B<[A]       # B = next digit
O<B         # output

Z<1         # halt
